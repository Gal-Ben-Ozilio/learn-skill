{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_DIR}/hooks/scripts/track-session-events.sh\"",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "bash \"${PLUGIN_DIR}/hooks/scripts/inject-learn-nudge.sh\"",
        "timeout": 3
      }
    ]
  }
}
